# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Configuration
# Who may sign in at /login and edit the site. One address, or several
# separated by commas. Must match mad_is_admin() in migration 002.
ADMIN_EMAIL=madeline@example.com,someone-else@example.com

# SMS sign-in via Bird (Supabase "Send SMS Hook")
# Only needed if you offer the text-a-code option. Supabase's built-in
# MessageBird provider speaks the legacy API and rejects Bird-platform keys,
# so Supabase posts the code to /api/auth/sms-hook and we send it ourselves.
# The region is read from the access key prefix (bk_us1_... -> us1).
SEND_SMS_HOOK_SECRET=v1,whsec_your_hook_secret_from_supabase
BIRD_ACCESS_KEY=bk_us1_your_bird_access_key
# Optional overrides:
# BIRD_OTP_TEMPLATE=bird_otp_verification
# BIRD_API_BASE=https://us1.platform.bird.com
